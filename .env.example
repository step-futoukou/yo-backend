# サーバー設定
# Render では PORT は自動で割り当てられるため設定不要（コードは process.env.PORT を優先）。
PORT=3000

# データベースファイルのパス（未設定なら ./yo.db）
# ※ Render 無料プランのディスクは揮発性。再起動でDBはリセットされる前提。
DB_PATH=./yo.db

# CORS 許可オリジン（カンマ区切りで複数指定可）。未設定時は http://localhost:5173 を許可。
#   例: CORS_ORIGIN=https://yo-frontend.onrender.com
CORS_ORIGIN=http://localhost:5173

# 実行環境
NODE_ENV=development
